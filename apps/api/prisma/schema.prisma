// Prisma schema — generated from AGENTS/DATABASE.md specification
// All models map to snake_case PostgreSQL tables and columns

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// ROLES — Fixed RBAC definitions (seeded at startup)
// ──────────────────────────────────────────────
model Role {
  id          String  @id @default(uuid())
  name        String  @unique @db.VarChar(50)
  description String? @db.Text

  users User[]

  @@map("roles")
}

// ──────────────────────────────────────────────
// USERS — Authentication and identity
// ──────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  roleId       String   @map("role_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role         Role          @relation(fields: [roleId], references: [id])
  reports      Report[]
  userProjects UserProject[]

  @@map("users")
}

// ──────────────────────────────────────────────
// PROJECTS — Work categories / tags for reports
// ──────────────────────────────────────────────
model Project {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  reports      Report[]
  userProjects UserProject[]

  @@map("projects")
}

// ──────────────────────────────────────────────
// USER_PROJECTS — Many-to-many: which users are assigned to which projects
// ──────────────────────────────────────────────
model UserProject {
  userId     String   @map("user_id")
  projectId  String   @map("project_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@map("user_projects")
}

// ──────────────────────────────────────────────
// REPORTS — Core entity: weekly reports with fixed fields
// ──────────────────────────────────────────────
model Report {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  projectId      String    @map("project_id")
  weekStartDate  DateTime  @map("week_start_date") @db.Date
  weekEndDate    DateTime  @map("week_end_date") @db.Date
  tasksCompleted String    @map("tasks_completed") @db.Text
  tasksPlanned   String    @map("tasks_planned") @db.Text
  blockers       String    @db.Text
  hoursWorked    Decimal?  @map("hours_worked") @db.Decimal(5, 2)
  notesOrLinks   String?   @map("notes_or_links") @db.Text
  status         String    @default("DRAFT") @db.VarChar(20)
  submittedAt    DateTime? @map("submitted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([userId, projectId, weekStartDate])
  @@index([userId])
  @@index([projectId])
  @@index([weekStartDate])
  @@map("reports")
}
