# Copy to `.env` (gitignored) before running `docker compose up`.
# docker compose reads this file automatically from the repo root.

# ── Database (local Postgres container) ─────────────────────────────
# These seed the postgres service and build the api's DATABASE_URL.
POSTGRES_USER=sisenco
POSTGRES_PASSWORD=sisenco
POSTGRES_DB=sisenco_reports

# ── Auth ────────────────────────────────────────────────────────────
# REQUIRED — the api will not start without it. Use a long random string:
#   openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Bootstrap manager (seeded once) ─────────────────────────────────
SEED_MANAGER_EMAIL=manager@sisenco.local
SEED_MANAGER_PASSWORD=ChangeMe123!

# ── AI chat (bonus, optional) ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Host port mappings (change if these are taken) ──────────────────
WEB_PORT=3000
API_PORT=3001
POSTGRES_PORT=5432

# FRONTEND_URL is the browser origin CORS trusts; keep in sync with WEB_PORT.
FRONTEND_URL=http://localhost:3000
